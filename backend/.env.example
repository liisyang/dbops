# Database Configuration
POSTGRES_HOST=0.0.0.0  # 开发环境 My/PostgreSQL 地址，部署时改为实际 IP
POSTGRES_PORT=5432
POSTGRES_DB=dbops
POSTGRES_USER=dbops
POSTGRES_PASSWORD=db20240910

# Security
SECRET_KEY=your-secret-key-here-change-in-production

# Redis
REDIS_URL=redis://0.0.0.0:6379/0  # 开发环境 Redis 地址，部署时改为实际 IP

# SSH (for Ansible operations)
SSH_USER=dbaacc
SSH_PASSWORD=
SSH_KEY=~/.ssh/id_ed25519
SSH_USER_GROUP=dba
SSH_USER_HOME_PREFIX=/home
SSH_PROFILE_PATH=/home
SSH_PORT=22
SSH_TIMEOUT=30

# Ansible
ANSIBLE_TIMEOUT=10
ANSIBLE_FORKS=20

# Host Check
HOST_CHECK_INTERVAL=600

# CORS (comma-separated list of origins, empty for same-origin only)
CORS_ORIGINS=
